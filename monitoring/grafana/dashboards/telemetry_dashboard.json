{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Space Telemetry Anomaly Detection — Live API Metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Total Prediction Requests",
      "description": "Total number of telemetry rows sent to /predict endpoint via Kafka",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "targets": [{
        "expr": "telemetry_prediction_requests_total",
        "legendFormat": "Requests",
        "refId": "A"
      }]
    },

    {
      "id": 2,
      "title": "Anomalies Detected",
      "description": "Total rows where anomaly_flag = -1 (Isolation Forest flagged as anomaly)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "targets": [{
        "expr": "telemetry_anomalies_detected_total",
        "legendFormat": "Anomalies",
        "refId": "A"
      }]
    },

    {
      "id": 3,
      "title": "Prediction Failures",
      "description": "Total API errors — 500 responses from /predict endpoint",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [{
        "expr": "telemetry_prediction_failures_total",
        "legendFormat": "Failures",
        "refId": "A"
      }]
    },

    {
      "id": 4,
      "title": "Anomaly Detection Rate (%)",
      "description": "Percentage of requests that were flagged as anomalies",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [{
        "expr": "100 * telemetry_anomalies_detected_total / clamp_min(telemetry_prediction_requests_total, 1)",
        "legendFormat": "Anomaly Rate %",
        "refId": "A"
      }]
    },

    {
      "id": 5,
      "title": "Prediction Request Rate (per second)",
      "description": "Rate of /predict requests over the last 1 minute — reflects Kafka streaming speed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false
          },
          "unit": "reqps",
          "mappings": []
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "expr": "rate(telemetry_prediction_requests_total[1m])",
        "legendFormat": "Requests/sec",
        "refId": "A"
      }]
    },

    {
      "id": 6,
      "title": "Anomaly Detection Rate Over Time",
      "description": "Rate of anomaly detections per second — spikes indicate engine degradation events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false
          },
          "unit": "reqps",
          "mappings": []
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "expr": "rate(telemetry_anomalies_detected_total[1m])",
        "legendFormat": "Anomalies/sec",
        "refId": "A"
      }]
    },

    {
      "id": 7,
      "title": "API Prediction Latency — p50 / p90 / p99",
      "description": "How long each /predict call takes — p99 shows worst-case inference time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "s",
          "mappings": []
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(telemetry_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p50 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, rate(telemetry_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p90 latency",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(telemetry_prediction_latency_seconds_bucket[1m]))",
          "legendFormat": "p99 latency",
          "refId": "C"
        }
      ]
    },

    {
      "id": 8,
      "title": "Average Prediction Latency",
      "description": "Mean time per prediction request in milliseconds",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "s",
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [{
        "expr": "rate(telemetry_prediction_latency_seconds_sum[1m]) / clamp_min(rate(telemetry_prediction_latency_seconds_count[1m]), 0.001)",
        "legendFormat": "Avg Latency",
        "refId": "A"
      }]
    },

    {
      "id": 9,
      "title": "Total Requests vs Anomalies — Cumulative",
      "description": "Cumulative comparison of all predictions vs anomaly detections over the streaming session",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short",
          "mappings": []
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "telemetry_prediction_requests_total",
          "legendFormat": "Total Requests",
          "refId": "A"
        },
        {
          "expr": "telemetry_anomalies_detected_total",
          "legendFormat": "Anomalies Detected",
          "refId": "B"
        },
        {
          "expr": "telemetry_prediction_failures_total",
          "legendFormat": "Failures",
          "refId": "C"
        }
      ]
    },

    {
      "id": 10,
      "title": "API Success Rate (%)",
      "description": "Percentage of prediction requests that succeeded without errors",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{
        "expr": "100 * (1 - telemetry_prediction_failures_total / clamp_min(telemetry_prediction_requests_total, 1))",
        "legendFormat": "Success Rate",
        "refId": "A"
      }]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["space-telemetry", "anomaly-detection", "kafka", "fastapi"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Space Telemetry — Live API Monitoring",
  "uid": "space-telemetry-v1",
  "version": 1
}